<div class="auth-page">
  <div class="auth-card">
    <div class="auth-header">
      <i class="bi bi-emoji-smile-fill" style="color:var(--secondary)"></i>
      <h1>Kids Login</h1>
      <p>Ask a parent for their email address</p>
    </div>

    <form action="/login/kids/family" method="POST">
      <%- csrf() %>
      <div class="form-group">
        <label><i class="bi bi-envelope"></i> Parent's Email</label>
        <input type="email" name="email" required autofocus placeholder="parent@email.com"/>
      </div>
      <button type="submit" class="btn btn-primary btn-block">
        <i class="bi bi-arrow-right"></i> Find My Family
      </button>
    </form>

    <p class="auth-footer"><a href="/login"><i class="bi bi-arrow-left"></i> Back</a></p>
  </div>
</div>

<style>
.auth-page  { max-width: 420px; margin: 2rem auto; padding: 0 1rem; }
.auth-card  { background: white; border-radius: 16px; padding: 2.5rem; box-shadow: 0 4px 24px rgba(0,0,0,0.08); }
.auth-header { text-align: center; margin-bottom: 2rem; }
.auth-header i  { font-size: 2.5rem; }
.auth-header h1 { font-size: 1.6rem; color: var(--primary); margin: 0.5rem 0 0.3rem; }
.auth-header p  { color: var(--muted); font-size: 0.9rem; }
.auth-footer { text-align: center; margin-top: 1.5rem; font-size: 0.88rem; }
.auth-footer a { color: var(--muted); }
</style>
