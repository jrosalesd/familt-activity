<form action="<%= route('admin.members.store') %>" method="POST" class="edit-form">
  <%- csrf() %>

  <div class="form-group">
    <label><i class="bi bi-person"></i> Name</label>
    <input type="text" name="name" required placeholder="e.g. Alice"/>
  </div>

  <div class="form-group">
    <label><i class="bi bi-shield"></i> Role</label>
    <select name="role" id="role-select" required>
      <% roles.forEach(r => { %>
        <option value="<%= r.value %>" data-uses-pin="<%= r.uses_pin %>" <%= r.uses_pin ? 'selected' : '' %>>
          <%= r.label %>
        </option>
      <% }) %>
    </select>
    <small id="role-hint" style="color:#888"></small>
  </div>

  <div class="form-group">
    <label><i class="bi bi-palette"></i> Avatar Colour</label>
    <div class="color-picker">
      <% ['#e74c3c','#e67e22','#f1c40f','#2ecc71','#1abc9c','#3498db','#9b59b6','#e91e63','#5b4fcf','#1e1b4b'].forEach((color, i) => { %>
        <label class="color-swatch">
          <input type="radio" name="avatar_color" value="<%= color %>" <%= i === 5 ? 'checked' : '' %>/>
          <span style="background:<%= color %>"></span>
        </label>
      <% }) %>
    </div>
  </div>

  <%# PIN fields — shown for roles with uses_pin = true %>
  <div id="pin-fields" style="display:none">
    <div class="form-group">
      <label><i class="bi bi-lock"></i> PIN</label>

      <%# PIN length selector %>
      <div class="pin-length-selector">
        <span class="pin-length-label">PIN length:</span>
        <div class="pin-length-options">
          <% [4,5,6,7,8].forEach(n => { %>
            <button type="button"
              class="pin-length-btn <%= n === 4 ? 'active' : '' %>"
              data-length="<%= n %>"
              onclick="setAdminPinLength(<%= n %>)">
              <%= n %>
            </button>
          <% }) %>
        </div>
      </div>

      <%# Dynamic dot display %>
      <div class="pin-display" id="admin-pin-display" style="justify-content:flex-start;gap:0.5rem;margin:0.75rem 0"></div>

      <%# PIN pad %>
      <div class="pin-pad" style="max-width:240px">
        <% [1,2,3,4,5,6,7,8,9].forEach(n => { %>
          <button type="button" class="pin-btn" onclick="addAdminPin('<%= n %>')"><%= n %></button>
        <% }) %>
        <button type="button" class="pin-btn pin-btn-clear" onclick="clearAdminPin()">
          <i class="bi bi-arrow-left"></i>
        </button>
        <button type="button" class="pin-btn" onclick="addAdminPin('0')">0</button>
        <button type="button" class="pin-btn pin-btn-ok" id="admin-pin-ok" style="opacity:0.4" disabled>
          <i class="bi bi-check-lg"></i>
        </button>
      </div>

      <small id="admin-pin-hint">Enter a 4-digit PIN</small>

      <%# Hidden fields submitted with the form %>
      <input type="hidden" name="pin"        id="admin-pin-value"/>
      <input type="hidden" name="pin_length" id="admin-pin-length" value="4"/>
    </div>
  </div>

  <%# Password fields — shown for roles with uses_pin = false %>
  <div id="password-fields">
    <div class="form-group">
      <label><i class="bi bi-envelope"></i> Email</label>
      <input type="email" name="email" placeholder="their@email.com"/>
    </div>
    <div class="form-group">
      <label><i class="bi bi-key"></i> Password</label>
      <div class="input-with-toggle">
        <input type="password" name="password" id="password-field" minlength="8" placeholder="Min 8 characters"/>
        <button type="button" class="toggle-password">
          <i class="bi bi-eye" id="toggle-icon"></i>
        </button>
      </div>
    </div>
  </div>

  <div class="form-group">
    <label class="toggle-label form-check">
      <input type="checkbox" name="is_temporary" id="is_temporary"/> Temporary member
    </label>
    <small>Temporary members expire after a set date</small>
  </div>

  <div id="expiry-field" style="display:none" class="form-group">
    <label><i class="bi bi-calendar"></i> Expires At</label>
    <input type="date" name="expires_at"/>
  </div>

  <div class="action-bar">
    <button type="submit" class="btn btn-primary">
      <i class="bi bi-person-plus"></i> Add Member
    </button>
    <a href="<%= route('admin.members.index') %>" class="btn btn-secondary">Cancel</a>
  </div>
</form>

<style>
.color-picker        { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.3rem; }
.color-swatch input  { display: none; }
.color-swatch span   { display: block; width: 30px; height: 30px; border-radius: 50%; cursor: pointer; border: 3px solid transparent; transition: border-color 0.15s; }
.color-swatch input:checked + span { border-color: #1e1b4b; }
.input-with-toggle   { position: relative; }
.input-with-toggle input { padding-right: 3rem; width: 100%; }
.toggle-password     { position: absolute; right: 0.75rem; top: 50%; transform: translateY(-50%); background: none; border: none; color: #888; cursor: pointer; font-size: 1rem; padding: 0; }
.toggle-password:hover { color: #1e1b4b; }
small                { color: #888; font-size: 0.8rem; display: block; margin-top: 0.3rem; }
.pin-length-selector { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem; }
.pin-length-label    { font-size: 0.85rem; color: #888; white-space: nowrap; }
.pin-length-options  { display: flex; gap: 0.4rem; }
.pin-length-btn      { width: 34px; height: 34px; border-radius: 8px; border: 2px solid #ddd; background: #f4f6fb; font-weight: 700; font-size: 0.85rem; cursor: pointer; transition: all 0.15s; }
.pin-length-btn.active { background: var(--primary, #5b4fcf); border-color: var(--primary, #5b4fcf); color: white; }
</style>

<script>const rolesData = <%- JSON.stringify(roles) %>;</script>
