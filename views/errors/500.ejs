<div class="error-page">
  <div class="error-badge">500</div>
  <div class="error-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
  <h1>Something Went Wrong</h1>
  <p>An unexpected error occurred. Our team has been notified.</p>

  <% if (error && error.message) { %>
  <div class="error-detail">
    <div class="error-detail-header">
      <i class="bi bi-bug-fill"></i> Error Detail
      <button class="error-copy-btn" 
              data-copy-source="error-message"
              data-copy-message="Error copied!">
        <i class="bi bi-clipboard"></i> Copy
      </button>
    </div>
    <pre id="error-message"><%= error.message %><% if (error.stack) { %>

Stack Trace:
<%= error.stack %><% } %></pre>
  </div>
  <% } %>

  <div class="error-actions">
    <a href="/" class="btn btn-primary"><i class="bi bi-house"></i> Go Home</a>
    <a href="javascript:history.back()" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Go Back</a>
    <button onclick="location.reload()" class="btn btn-secondary"><i class="bi bi-arrow-clockwise"></i> Retry</button>
  </div>

  <div class="error-footer">
    <span><i class="bi bi-clock"></i> <%= new Date().toLocaleString() %></span>
    <% if (typeof currentPath !== 'undefined') { %>
      <span><i class="bi bi-link-45deg"></i> <%= currentPath %></span>
    <% } %>
  </div>
</div>

<style>
.error-page   { text-align: center; padding: 3rem 1rem; max-width: 700px; margin: 0 auto; }
.error-badge  { display: inline-block; background: #fff0f0; color: #e74c3c; font-size: 4rem; font-weight: 900; border-radius: 16px; padding: 0.2rem 1.2rem; margin-bottom: 1rem; letter-spacing: -2px; }
.error-icon   { font-size: 2rem; color: #e74c3c; margin-bottom: 0.5rem; }
.error-page h1 { font-size: 1.8rem; color: #1e1b4b; margin-bottom: 0.5rem; }
.error-page > p { color: #888; margin-bottom: 1.5rem; }
.error-detail { background: #1e1b4b; border-radius: 12px; padding: 1.2rem; margin: 1.5rem 0; text-align: left; }
.error-detail-header { display: flex; align-items: center; gap: 0.5rem; color: #a5b4fc; font-size: 0.85rem; font-weight: 700; margin-bottom: 0.8rem; }
.error-detail-header .error-copy-btn { margin-left: auto; background: rgba(255,255,255,0.1); border: none; color: #a5b4fc; border-radius: 6px; padding: 0.2rem 0.6rem; cursor: pointer; font-size: 0.8rem; }
.error-detail-header .error-copy-btn:hover { background: rgba(255,255,255,0.2); }
.error-detail pre { color: #e2e8f0; font-size: 0.8rem; white-space: pre-wrap; word-break: break-all; margin: 0; max-height: 300px; overflow-y: auto; }
.error-actions { display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; margin: 1.5rem 0; }
.error-footer  { display: flex; gap: 1.5rem; justify-content: center; color: #aaa; font-size: 0.8rem; flex-wrap: wrap; }
.error-footer span { display: flex; align-items: center; gap: 0.3rem; }
</style>
