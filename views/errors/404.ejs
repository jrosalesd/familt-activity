<div class="error-page">
  <div class="error-badge">404</div>
  <div class="error-icon"><i class="bi bi-search"></i></div>
  <h1>Page Not Found</h1>
  <p>The page you're looking for doesn't exist or has been moved.</p>

  <div class="error-suggestions">
    <p class="suggestions-title">Here are some helpful links:</p>
    <div class="suggestions-grid">
      <a href="/" class="suggestion-card">
        <i class="bi bi-house-fill"></i>
        <span>Home</span>
      </a>
      <% if (member) { %>
        <% if (typeof safeRoute === 'function') { %>
          <a href="<%= safeRoute('app.admin.dashboard') %>" class="suggestion-card">
            <i class="bi bi-speedometer2"></i>
            <span>Dashboard</span>
          </a>
          <a href="<%= safeRoute('admin.members.index') %>" class="suggestion-card">
            <i class="bi bi-people-fill"></i>
            <span>Members</span>
          </a>
          <a href="<%= safeRoute('admin.tasks.index') %>" class="suggestion-card">
            <i class="bi bi-check2-square"></i>
            <span>Tasks</span>
          </a>
        <% } %>
      <% } else { %>
        <a href="/login" class="suggestion-card">
          <i class="bi bi-box-arrow-in-right"></i>
          <span>Login</span>
        </a>
        <a href="/register" class="suggestion-card">
          <i class="bi bi-person-plus-fill"></i>
          <span>Register</span>
        </a>
      <% } %>
      <a href="javascript:history.back()" class="suggestion-card">
        <i class="bi bi-arrow-left-circle-fill"></i>
        <span>Go Back</span>
      </a>
    </div>
  </div>

  <div class="error-footer">
    <span><i class="bi bi-clock"></i> <%= new Date().toLocaleString() %></span>
    <% if (typeof currentPath !== 'undefined') { %>
      <span><i class="bi bi-link-45deg"></i> <%= currentPath %></span>
    <% } %>
  </div>
</div>

<style>
.error-page        { text-align: center; padding: 3rem 1rem; max-width: 600px; margin: 0 auto; }
.error-badge       { display: inline-block; background: #f0f4ff; color: #5b4fcf; font-size: 4rem; font-weight: 900; border-radius: 16px; padding: 0.2rem 1.2rem; margin-bottom: 1rem; letter-spacing: -2px; }
.error-icon        { font-size: 2rem; color: #5b4fcf; margin-bottom: 0.5rem; }
.error-page h1     { font-size: 1.8rem; color: #1e1b4b; margin-bottom: 0.5rem; }
.error-page > p    { color: #888; margin-bottom: 2rem; }
.error-suggestions { margin-bottom: 2rem; }
.suggestions-title { font-size: 0.85rem; color: #aaa; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 700; margin-bottom: 1rem; }
.suggestions-grid  { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
.suggestion-card   { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; background: white; border-radius: 12px; padding: 1.2rem 1.5rem; text-decoration: none; color: #1e1b4b; box-shadow: 0 2px 8px rgba(0,0,0,0.07); transition: transform 0.15s, box-shadow 0.15s; min-width: 90px; }
.suggestion-card:hover { transform: translateY(-3px); box-shadow: 0 6px 16px rgba(0,0,0,0.12); color: #5b4fcf; }
.suggestion-card i { font-size: 1.5rem; color: #5b4fcf; }
.suggestion-card span { font-size: 0.85rem; font-weight: 600; }
.error-footer      { display: flex; gap: 1.5rem; justify-content: center; color: #aaa; font-size: 0.8rem; flex-wrap: wrap; }
.error-footer span { display: flex; align-items: center; gap: 0.3rem; }
</style>
